# Contoh environment variable yang dibutuhkan saat deploy ke Railway.
# JANGAN diisi nilai asli di file ini -- isi nilai aslinya langsung di
# dashboard Railway (Settings > Variables), bukan di file yang ikut di-commit.

# Generate baru, jangan pakai nilai default di settings.py
SECRET_KEY=ganti-dengan-secret-key-baru-yang-acak

# Production harus False
DEBUG=False

# Domain Railway kamu, contoh: simplelms.up.railway.app
# Boleh lebih dari satu, pisahkan dengan koma
ALLOWED_HOSTS=simplelms.up.railway.app

# Otomatis terisi oleh Railway saat menambahkan PostgreSQL service,
# tidak perlu diisi manual.
DATABASE_URL=postgresql://user:password@host:port/dbname
